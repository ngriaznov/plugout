{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "plugout",
  "identifier": "com.plugout.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "plugout",
        "width": 1040,
        "height": 720,
        "minWidth": 820,
        "minHeight": 520,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMxRjlDNDlCM0NGOTkyNDUKUldSRmt2azhtOFQ1TVhvU1ZSc3FEVHNMUlRkcURra1dwVWJiMGM2ZWxVOVNuekQ3d3MvUGdXekkK",
      "endpoints": [
        "https://github.com/ngriaznov/plugout/releases/latest/download/latest.json"
      ]
    }
  }
}
